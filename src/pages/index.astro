	}

	{/* ============================================================ */}
	{/* INSIGHTS — recent posts                                      */}
	{/* ============================================================ */}
	{
		recent.length > 0 && (
			<section class="bg-paper px-5 py-16 sm:px-10 sm:py-20 lg:px-12 lg:py-28">
				<div class="mx-auto grid max-w-[var(--container-site)] grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
					{/* Left col — eyebrow + heading only. Arrows now overlay the rail. */}
					<div class="lg:col-span-4">
						<Eyebrow label="Our blog" />
						<h2 class="mt-5 font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold leading-[1.1] tracking-tight text-ink">
							Inspiring insights for a smarter,{" "}
							<span class="text-ink-mute">greener</span> future
						</h2>
					</div>

					{/* Right col — horizontal scroll rail of post cards, with prev/next arrows overlaid on the side edges of the image row, like the screenshot. */}
					<div class="relative lg:col-span-8">
						<div
							class="insights-rail flex scroll-smooth gap-5 overflow-x-auto pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden lg:gap-6"
						>
							{recent.map((p) => (
								<InsightCard
									post={p}
									class="insights-card flex w-[80%] shrink-0 sm:w-[55%] lg:w-[calc(50%-12px)]"
								/>
							))}
						</div>
						{/* Arrows overlay the side edges of the rail, vertically       */}
						{/* aligned with the card image (~1/3 down from rail top since  */}
						{/* image is aspect-[4/3] then meta+title+excerpt below).       */}
						<RailButton
							direction="prev"
							ariaLabel="Previous insights"
							class="absolute left-2 top-[33%] z-10 hidden -translate-y-1/2 sm:inline-flex"
							data-insights-scroll-prev
						/>
						<RailButton
							direction="next"
							ariaLabel="Next insights"
							class="absolute right-2 top-[33%] z-10 hidden -translate-y-1/2 sm:inline-flex"
							data-insights-scroll-next
