---

{/* Hero image is self-hosted at /hero/dam-{800,1400,2400}.webp +
   a JPG fallback. Preloading the 800w variant since mobile-first;
   browsers picking the 1400/2400 from srcset still skip the preload
   (a smaller URL match means the preload kept its slot). */}
<MainLayout
	title="Geosynthetics Manufacturers in India | Geomembranes & Geogrids by Ocean Geosynthetics"
	description="India's leading geosynthetics manufacturer and exporter of geotextiles, geomembranes, geogrids and geocells. 3,000+ projects delivered, 14 sectors served, 25+ years of engineering depth."
	heroPreload="/hero/dam-800.webp"
>
	{/* ============================================================ */}
	{/* HERO — 100vh full bleed; copy top-anchored on the left, rich */}
	{/* featured-case-study card on the right (links to the most     */}
	{/* recent post in the "case-studies" WP category).              */}
	{/* ============================================================ */}
	<section class="relative min-h-[600px] w-full sm:min-h-[700px] sm:h-screen">
		{/* Hero — self-hosted WebP variants on the CF Pages edge cache.   */}
		{/* Mobile fetches ~67 KiB (800w) instead of the 255 KiB Unsplash */}
		{/* 2400-wide. <picture> falls back to the JPG copy for browsers  */}
		{/* without WebP (vanishingly few in 2026 but cheap to keep).      */}
		<picture>
			<source
				type="image/webp"
				srcset="/hero/dam-800.webp 800w, /hero/dam-1400.webp 1400w, /hero/dam-2400.webp 2400w"
				sizes="100vw"
			/>
			<img
				src="/hero/dam-1400.jpg"
				width="2400"
				height="1600"
				alt="Hydroelectric reservoir dam: Ocean Geosynthetics geomembrane and geogrid infrastructure project in India"
				class="absolute inset-0 h-full w-full object-cover [clip-path:inset(0)]"
				fetchpriority="high"
				decoding="async"
			/>
		</picture>
		{/* Base dark overlay — keeps copy legible across the whole image */}
		<div class="absolute inset-0 bg-black/35" aria-hidden="true"></div>
		{/* Top fade — keeps header legible on lighter parts of the photo */}
		<div
			class="absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-black/55 via-black/15 to-transparent"
			aria-hidden="true"
		>
		</div>
		{/* Side fade behind the headline area */}
		<div
			class="absolute inset-y-0 left-0 w-2/3 bg-gradient-to-r from-black/45 via-black/15 to-transparent"
			aria-hidden="true"
		>
		</div>

		{/* Headline pinned bottom-left, case-study card flush to hero's bottom edge on lg */}
		<div
			class="relative mx-auto h-full max-w-[var(--container-site)] px-5 pt-28 pb-10 sm:px-10 sm:pt-40 sm:pb-20 lg:px-12 lg:pt-32 lg:pb-0"
		>
			<div class="grid h-full grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
				{/* Headline + single CTA — bottom-anchored on desktop, kept elevated above the flush card */}
				<div class="lg:col-span-7 lg:self-end lg:pb-24">
					<h1
						class="font-display text-[clamp(1.875rem,4.75vw,3.5rem)] font-bold leading-[1.05] tracking-tight text-white drop-shadow-lg"
						aria-label="Geosynthetics Manufacturers in India, Exporter of Geomembranes and Geosynthetics."
					>
						Geosynthetics <span class="text-brand-accent">Manufacturers</span> In India, <span class="text-brand-accent">Exporter</span> Of Geomembranes &amp; Geosynthetics.
					</h1>
					<p
						class="mt-6 font-sans text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-accent drop-shadow"
					>
						Reliable &amp; High Quality Products
					</p>
					<p
						class="mt-3 max-w-xl font-sans text-base text-white/90 drop-shadow sm:text-lg"
					>
						As a leading geosynthetic material supplier &amp; manufacturer in
						India, we offer geosynthetic products including geotextile, geogrid,
						geomembranes, geocomposite and geonets.
					</p>
					<div class="mt-8">
						<PillLink href="/our-products/">See Our Products</PillLink>
					</div>
				</div>

				{/* Featured case study card — bottom-aligned with the hero edge.
				    The .blend-bottom-corners class carves concave quarter-circles
				    out of the bottom-left/right so the card visually tucks into
				    the hero's bottom edge instead of floating on top of it. */}
				<div class="lg:col-span-4 lg:col-start-9 lg:self-end">
					<a
						href={featuredCaseStudy?.uri || "/case-studies/"}
						class="card-bottom-tabs group relative block rounded-card bg-white p-5 shadow-[0_18px_40px_-10px_rgba(0,0,0,0.35)] transition-shadow duration-300 hover:shadow-[0_22px_50px_-10px_rgba(0,0,0,0.45)] sm:p-6 lg:rounded-b-none lg:shadow-[0_-25px_50px_-15px_rgba(0,0,0,0.3)] lg:hover:shadow-[0_-30px_60px_-15px_rgba(0,0,0,0.4)]"
					>
						<p
							class="font-sans text-[10px] font-semibold uppercase tracking-[0.18em] text-ink-mute"
						>
							Featured case study
						</p>
						<h3
