	topIcon: "M4 6h16v4H4zM4 14h16v4H4z",
	bottomArt: "M4 14h56v6H4zM4 26h56v6H4z",
};

function getProductGlyph(uri: string | undefined): ProductGlyph {
	if (!uri) return DEFAULT_PRODUCT_GLYPH;
	for (const slug of Object.keys(PRODUCT_GLYPHS)) {
		if (uri.includes(slug)) return PRODUCT_GLYPHS[slug];
	}
	return DEFAULT_PRODUCT_GLYPH;
}

const FALLBACK_SECTOR_BULLETS = [
