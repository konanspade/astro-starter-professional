		/* Satellite hover — fill flips to brand green, stroke matches,
		   and the inner icon flips to white for contrast. The transition
		   is on each property individually so the colour change feels
		   deliberate rather than abrupt. */
		.solutions-hub-node-circle {
			transition: fill 0.35s cubic-bezier(0.22, 1, 0.36, 1),
				stroke 0.35s cubic-bezier(0.22, 1, 0.36, 1),
				stroke-width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
		}
		.solutions-hub-node-icon {
			transition: color 0.35s cubic-bezier(0.22, 1, 0.36, 1);
		}
		.solutions-hub-node:hover .solutions-hub-node-circle {
			fill: var(--color-brand-accent);
			color: var(--color-brand-accent);
			stroke-width: 2;
		}
		.solutions-hub-node:hover .solutions-hub-node-icon {
			color: white;
		}

		/* Testimonials marquee — translates the rail by half its width so
		   the duplicated array seam is invisible. Linear ease so motion is
		   constant; pause on hover so users can read a card without it
		   sliding out from under them. Reduced-motion users get a static
		   row with overflow-x scroll instead. */
		.testimonial-rail {
			animation: testimonial-marquee 50s linear infinite;
		}
		.testimonials-marquee:hover .testimonial-rail {
			animation-play-state: paused;
		}
		@keyframes testimonial-marquee {
			from {
				transform: translateX(0);
			}
			to {
				transform: translateX(-50%);
			}
		}
		@media (prefers-reduced-motion: reduce) {
			.testimonial-rail {
				animation: none;
			}
		}
	</style>

	{/* ============================================================ */}
	{/* TESTIMONIALS — full-bleed dark image bg + CSS-marquee row of */}
	{/* white quote cards. Cards loop seamlessly by duplicating the  */}
	{/* TESTIMONIALS array twice. Pause on hover.                    */}
	{/* ============================================================ */}
	<section class="testimonials-section relative overflow-hidden py-16 sm:py-20 lg:py-28">
		{/* Aerial bg + dark overlay */}
		<img
			src="/images/forest-aerial-1600.webp"
			alt=""
			aria-hidden="true"
			class="absolute inset-0 h-full w-full object-cover"
			loading="lazy"
		/>
		<div class="absolute inset-0 bg-black/70" aria-hidden="true"></div>

		<div class="relative">
			<div class="mx-auto max-w-3xl px-6 text-center sm:px-10 lg:px-12">
				<Eyebrow label="Clients" tone="white" />
