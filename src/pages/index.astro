// Per-case-study stats for the Case Studies cards. Keyed by URI slug
// fragment so we can match against the WP permalink. Each entry is
// exactly two stat rows; if a case study isn't mapped here the card
// renders without stats (still shows title, image, CTA).
const CASE_STUDY_STATS: Record<string, { value: string; label: string }[]> = {
	"reliance-bio-energy-project-reinforced-with-geogrid": [
		{ value: "120 kN/m", label: "Geogrid tensile strength" },
		{ value: "8 m", label: "Wall height reinforced" },
	],
	"hdpe-liner-rcc-project-chhatrapati-sambhaji-nagar": [
		{ value: "1.5 mm", label: "HDPE liner spec" },
		{ value: "0%", label: "Seepage loss" },
	],
};

function getCaseStudyStats(node: Node): { value: string; label: string }[] {
	// Prefer ACF-managed stats from the `caseStudyStats` field group when
	// the editor has filled them in. Fall back to the in-repo map for any
	// post that hasn't been seeded yet.
	const acfStats = (node.caseStudyStats?.stats ?? [])
		.filter((s): s is { value: string; label: string } =>
			Boolean(s?.value && s?.label),
		)
		.slice(0, 2);
	if (acfStats.length > 0) return acfStats;

	const uri = node.uri;
	if (!uri) return [];
	for (const slug of Object.keys(CASE_STUDY_STATS)) {
		if (uri.includes(slug)) return CASE_STUDY_STATS[slug];
	}
	return [];
}

// Right-column highlight list — short subset of the WP solutions
// CPT, hand-picked for visual balance.
const SOLUTIONS_HIGHLIGHTS = [
	"Erosion control",
	"Soil stabilisation",
	"Drainage of structures",
	"Coastal protection",
	"Retaining walls",
	"Rockfall protection",
];

const apiUrl = import.meta.env.WORDPRESS_API_URL;

// Helper-plugin REST root, derived from the GraphQL endpoint host so we
// don't have to maintain a second env var. Used for options-page reads
// that wpgraphql-acf can't resolve cleanly (testimonials repeater).
const wpRestRoot = apiUrl
	? new URL("/wp-json/konanspade/v1", apiUrl).toString()
	: null;
const wpUser = import.meta.env.WP_APP_USERNAME;
const wpPass = import.meta.env.WP_APP_PASSWORD;
const wpAuthHeader = wpUser && wpPass
	? `Basic ${Buffer.from(`${wpUser}:${wpPass}`).toString("base64")}`
	: null;

let products: Node[] = [];
let sectors: Node[] = [];
let recent: Node[] = [];
let caseStudies: Node[] = [];
let featuredCaseStudy: Node | null = null;
let testimonials: { name: string; role: string; body: string }[] = [];

try {
	const response = await fetch(apiUrl, {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({
			query: `query Homepage {
				products(first: 12) {
					nodes { id title uri excerpt featuredImage { node { mediaItemUrl altText } } }
				}
				sectors(first: 30) {
					nodes {
						id title uri excerpt
						featuredImage { node { mediaItemUrl altText } }
						sectorBullets { bulletPoints { text } }
					}
				}
				posts(first: 8, where: {categoryNotIn: [16]}) {
					nodes {
						id title uri date excerpt
						featuredImage { node { mediaItemUrl altText } }
						categories { nodes { name slug } }
					}
				}
				caseStudies: posts(first: 4, where: {categoryName: "case-studies"}) {
					nodes {
						id title uri date excerpt
						featuredImage { node { mediaItemUrl altText } }
						caseStudyStats { stats { value label } }
					}
				}
				caseStudy: nodeByUri(uri: "/reliance-bio-energy-project-reinforced-with-geogrid/") {
					... on Post { id title uri excerpt featuredImage { node { mediaItemUrl altText } } }
				}
			}`,
		}),
	});
	const json = await response.json();
	products = json?.data?.products?.nodes ?? [];
	sectors = json?.data?.sectors?.nodes ?? [];
	caseStudies = json?.data?.caseStudies?.nodes ?? [];
	featuredCaseStudy = json?.data?.caseStudy ?? null;
	// Insights rail excludes the `case-studies` category (id 16) at query
	// level so we get a varied feed for the blog rail.
	recent = json?.data?.posts?.nodes ?? [];
} catch (err) {
	console.error("homepage: fetch failed", err);
}

// Pull testimonials off the Global ACF options page via the helper
// plugin REST endpoint. wpgraphql-acf v2's options-page bridge returns
// null for repeaters in this site's setup, so we hit REST directly.
// Falls back to the hardcoded TESTIMONIALS list if the call fails.
if (wpRestRoot && wpAuthHeader) {
	try {
		// Cache-bust query string + no-cache headers — LiteSpeed in front
		// of WP REST keeps a stale options-page response otherwise, so a
		// fresh seed wouldn't reach the build.
		const res = await fetch(
			`${wpRestRoot}/acf/options/global?_t=${Date.now()}`,
			{
				headers: {
					Authorization: wpAuthHeader,
					"Cache-Control": "no-cache",
					Pragma: "no-cache",
				},
			},
		);
		if (res.ok) {
			const data = await res.json();
			const items: { name: string; role: string; body: string }[] = Array.isArray(
				data?.testimonials,
			)
				? data.testimonials
				: [];
			testimonials = items.filter(
				(t) => t && t.name && t.role && t.body,
			);
		}
	} catch (err) {
		console.error("homepage: testimonials fetch failed", err);
	}
}

// Strip HTML from WP excerpts before display
function stripHtml(html: string | null | undefined): string {
	if (!html) return "";
	return html.replace(/<[^>]*>/g, "").replace(/\s+/g, " ").trim();
}

