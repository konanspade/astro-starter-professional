			</div>
		</div>
	</section>
</MainLayout>

{/* ===================================================================
   Driving Change — GSAP ScrollTrigger animations
   • Word reveal: each word in the heading fades from ink/15 → ink as the
     section scrolls past, on scrub. Accent (lime) words simply ramp in
     opacity since their color is already set inline.
   • Dual-column parallax: left and right card columns translate up at
     different speeds across the section's scroll range, producing the
     Mivora "depth" effect. We respect prefers-reduced-motion by skipping
     the parallax tweens entirely.
   =================================================================== */}
<script>
	// Dynamic imports — GSAP/ScrollTrigger ship as their own Vite chunks
	// fetched only when initHomepageAnimations runs (after `load` + idle
	// slot). Keeps the main thread free during FCP/LCP/TBT measurement.

	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	async function initHomepageAnimations(): Promise<void> {
		if (reduceMotion) return;
		const [{ gsap }, { ScrollTrigger }] = await Promise.all([
			import("gsap"),
			import("gsap/ScrollTrigger"),
		]);
		gsap.registerPlugin(ScrollTrigger);

	const section = document.querySelector<HTMLElement>("[data-dc-section]");
	const heading = document.querySelector<HTMLElement>("[data-dc-heading]");
	const letters = heading?.querySelectorAll<HTMLElement>("[data-dc-letter]");
	const cols = document.querySelectorAll<HTMLElement>("[data-dc-col]");

	if (heading && letters && letters.length) {
		gsap.set(letters, { opacity: 0.15 });
		gsap.to(letters, {
			opacity: 1,
			ease: "none",
			stagger: 1, // even spread across the scroll progress
			scrollTrigger: {
				trigger: heading,
				// Reveal completes by the time the heading reaches mid-viewport
				// (≈ half a screen of scroll past first contact).
				start: "top 75%",
				end: "top 25%",
				scrub: 0.4,
			},
		});
	}

	if (section && cols.length && !reduceMotion) {
		// Side cards start statically pushed 72px (sm) / 106px (lg)
		// below the middle card. Their parallax target rises slightly
		// less than that distance over the section's scroll range, so
		// side cards approach center but never cross above it.
		const offsets = [-18, -2, -18];
		cols.forEach((col, i) => {
			gsap.to(col, {
				yPercent: offsets[i] ?? -10,
				ease: "none",
				scrollTrigger: {
					trigger: section,
					start: "top bottom",
					end: "bottom top",
					scrub: true,
				},
			});
		});
	}

	/* Industries tabs — toggle aria-selected on buttons and the hidden
	   class on panels. Plain DOM, no framework, since the homepage is
	   otherwise static. */
	const industryTabs =
		document.querySelectorAll<HTMLButtonElement>("[data-industry-tab]");
	const industryPanels = document.querySelectorAll<HTMLElement>(
		"[data-industry-panel]",
	);
	industryTabs.forEach((tab) => {
		tab.addEventListener("click", () => {
			const target = tab.dataset.industryTab;
			industryTabs.forEach((t) => {
				const active = t === tab;
				t.setAttribute("aria-selected", active ? "true" : "false");
				t.dataset.state = active ? "active" : "inactive";
			});
			industryPanels.forEach((p) => {
				p.classList.toggle("hidden", p.dataset.industryPanel !== target);
			});
		});
	});

	/* Industries tab rail — symmetric prev/next arrows that auto-hide
	   when the rail is at the corresponding edge. data-at-start /
	   data-at-end attributes are mirrored across the buttons AND the
	   matching fade overlays so both fade together. */
	const industriesRail = document.querySelector<HTMLElement>(
		".industries-tabs-rail",
	);
	const industriesPrev = document.querySelector<HTMLButtonElement>(
		"[data-industries-scroll-prev]",
	);
	const industriesNext = document.querySelector<HTMLButtonElement>(
		"[data-industries-scroll-next]",
	);
	const industriesFadeStart = document.querySelector<HTMLElement>(
		'[data-industries-fade="start"]',
	);
	const industriesFadeEnd = document.querySelector<HTMLElement>(
		'[data-industries-fade="end"]',
	);
	if (industriesRail && industriesPrev && industriesNext) {
		const step = (): number =>
			Math.max(industriesRail.clientWidth * 0.7, 200);

		const updateEdgeState = (): void => {
			const max = industriesRail.scrollWidth - industriesRail.clientWidth;
			const atStart = industriesRail.scrollLeft <= 1;
			const atEnd = max <= 1 || industriesRail.scrollLeft >= max - 1;
			industriesPrev.dataset.atStart = atStart ? "true" : "false";
			industriesNext.dataset.atEnd = atEnd ? "true" : "false";
			if (industriesFadeStart) {
				industriesFadeStart.dataset.atStart = atStart ? "true" : "false";
			}
			if (industriesFadeEnd) {
				industriesFadeEnd.dataset.atEnd = atEnd ? "true" : "false";
			}
		};

		industriesPrev.addEventListener("click", () => {
			industriesRail.scrollBy({ left: -step(), behavior: "smooth" });
		});
		industriesNext.addEventListener("click", () => {
			industriesRail.scrollBy({ left: step(), behavior: "smooth" });
		});
		industriesRail.addEventListener("scroll", updateEdgeState, { passive: true });
		window.addEventListener("resize", updateEdgeState);
		updateEdgeState();
	}

	/* Solutions section — stat count-up + hub draw-in. */
	const solutionsSection = document.querySelector<HTMLElement>(
		"[data-solutions-section]",
	);
	if (solutionsSection) {
		// Hub diagram. Circle perimeter draws via stroke-dashoffset
		//    trick (set dasharray = full circumference; offset = circ →
		//    0). Lines fade in stagger; satellites pop in scale.
		const circle = solutionsSection.querySelector<SVGCircleElement>(
			"[data-hub-circle]",
		);
		const lines = solutionsSection.querySelectorAll<SVGLineElement>(
			"[data-hub-line]",
		);
		const center = solutionsSection.querySelector<SVGGElement>(
			"[data-hub-center]",
		);
		const nodes = solutionsSection.querySelectorAll<SVGGElement>(
			"[data-hub-node]",
		);

		if (circle && nodes.length) {
			// Perimeter circle draws via stroke-dashoffset. We swap the
			// resting dashed pattern for a solid stroke during the draw,
			// then restore on complete so the rest state is dashed again.
			const restPattern = circle.getAttribute("stroke-dasharray") ?? "";
			const r = parseFloat(circle.getAttribute("r") ?? "0");
			const circumference = 2 * Math.PI * r;

			gsap.set(circle, {
				strokeDasharray: circumference,
				strokeDashoffset: circumference,
				opacity: 0,
			});
			gsap.set(center, {
				scale: 0.4,
				opacity: 0,
				transformOrigin: "50% 50%",
			});
			gsap.set(nodes, {
				scale: 0,
				opacity: 0,
				transformOrigin: "50% 50%",
			});
			gsap.set(lines, { opacity: 0 });

			// Single timeline so everything shares pacing; defaultEase
			// keeps motion smooth across every segment.
			ScrollTrigger.create({
				trigger: solutionsSection,
				start: "top 65%",
				once: true,
				onEnter: () => {
					const tl = gsap.timeline({
						defaults: { ease: "expo.out" },
						onComplete: () => {
							// Once the diagram has assembled, start a slow,
							// continuous rotation on the dashed perimeter so it
							// reads as a living orbit rather than a static ring.
							// Linear ease + long duration keeps it meditative.
							// `svgOrigin` (GSAP-specific) sets the rotation
							// centre in SVG user units, sidestepping the
							// transform-box / transform-origin pitfalls CSS
							// has with SVG circles. 220 220 = the circle's
							// centre. Linear ease + long duration = meditative.
							gsap.to(circle, {
								rotation: 360,
								duration: 60,
								ease: "none",
								repeat: -1,
								svgOrigin: "220 220",
							});
						},
					});

					// 1. Perimeter — fade + draw simultaneously, slow, deliberate.
					tl.to(circle, { opacity: 1, duration: 0.4 })
						.to(
							circle,
							{
								strokeDashoffset: 0,
								duration: 1.6,
								ease: "power2.inOut",
								onComplete: () => {
									circle.setAttribute("stroke-dasharray", restPattern);
									circle.removeAttribute("stroke-dashoffset");
								},
							},
							"<0.05",
						);

					// 2. Centre hub — soft scale-in once perimeter is well underway.
					tl.to(
						center,
						{
							scale: 1,
							opacity: 1,
							duration: 0.9,
							ease: "back.out(1.4)",
						},
						"-=1.0",
					);

					// 3. Connector lines — soft stagger fade.
					tl.to(
						lines,
						{
							opacity: 1,
							duration: 0.7,
							stagger: { each: 0.08, from: "start" },
						},
						"-=0.55",
					);

					// 4. Satellites — float in with subtle Y rise, scaled stagger.
					tl.fromTo(
						nodes,
						{ scale: 0, opacity: 0, y: 8 },
						{
							scale: 1,
							opacity: 1,
							y: 0,
							duration: 0.85,
							stagger: { each: 0.09, from: "start" },
							ease: "back.out(1.5)",
						},
						"-=0.4",
					);
				},
			});

			// Hover — gentle scale + soft drop shadow via filter. The
			// fill colour change comes from CSS so it benefits from the
			// dedicated transition timing already declared there.
			nodes.forEach((node) => {
				node.addEventListener("mouseenter", () => {
					gsap.to(node, {
						scale: 1.08,
						duration: 0.45,
						ease: "expo.out",
					});
				});
				node.addEventListener("mouseleave", () => {
					gsap.to(node, {
						scale: 1,
						duration: 0.55,
						ease: "expo.out",
					});
				});
			});
		}
	}

	/* Catalog rail — same prev/next pattern as the industries rail. */
	const catalogRail = document.querySelector<HTMLElement>(".catalog-rail");
	const catalogPrev = document.querySelector<HTMLButtonElement>(
		"[data-catalog-scroll-prev]",
	);
	const catalogNext = document.querySelector<HTMLButtonElement>(
		"[data-catalog-scroll-next]",
	);
	if (catalogRail && catalogPrev && catalogNext) {
		// One click scrolls a full row of visible cards (4 on desktop,
		// 2 on tablet, 1 on mobile). Using the rail's clientWidth keeps
		// this responsive without hard-coding card counts per breakpoint.
		const cardStep = (): number => catalogRail.clientWidth;
		const updateCatalogEdges = (): void => {
			const max = catalogRail.scrollWidth - catalogRail.clientWidth;
			const atStart = catalogRail.scrollLeft <= 1;
			const atEnd = max <= 1 || catalogRail.scrollLeft >= max - 1;
			catalogPrev.dataset.atStart = atStart ? "true" : "false";
			catalogNext.dataset.atEnd = atEnd ? "true" : "false";
		};
		catalogPrev.addEventListener("click", () => {
			catalogRail.scrollBy({ left: -cardStep(), behavior: "smooth" });
		});
		catalogNext.addEventListener("click", () => {
			catalogRail.scrollBy({ left: cardStep(), behavior: "smooth" });
		});
		catalogRail.addEventListener("scroll", updateCatalogEdges, { passive: true });
		window.addEventListener("resize", updateCatalogEdges);
		updateCatalogEdges();
	}

	/* Insights rail — same prev/next pattern. Step = clientWidth so
	   one click advances exactly one screen of cards. */
	const insightsRail = document.querySelector<HTMLElement>(".insights-rail");
	const insightsPrev = document.querySelector<HTMLButtonElement>(
		"[data-insights-scroll-prev]",
	);
	const insightsNext = document.querySelector<HTMLButtonElement>(
		"[data-insights-scroll-next]",
	);
	if (insightsRail && insightsPrev && insightsNext) {
		// One click advances by exactly ONE card (not the visible viewport
		// width). Reads the first card's offsetWidth + the rail's column
		// gap so it works at every breakpoint.
		const step = (): number => {
			const card = insightsRail.querySelector<HTMLElement>(".insights-card");
			if (!card) return insightsRail.clientWidth;
			const gap = parseInt(
				getComputedStyle(insightsRail).columnGap || "20",
				10,
			);
			return card.offsetWidth + gap;
		};
		const updateEdges = (): void => {
			const max = insightsRail.scrollWidth - insightsRail.clientWidth;
			const atStart = insightsRail.scrollLeft <= 1;
			const atEnd = max <= 1 || insightsRail.scrollLeft >= max - 1;
			insightsPrev.dataset.atStart = atStart ? "true" : "false";
			insightsNext.dataset.atEnd = atEnd ? "true" : "false";
		};
		insightsPrev.addEventListener("click", () => {
			insightsRail.scrollBy({ left: -step(), behavior: "smooth" });
		});
		insightsNext.addEventListener("click", () => {
			insightsRail.scrollBy({ left: step(), behavior: "smooth" });
		});
		insightsRail.addEventListener("scroll", updateEdges, { passive: true });
		window.addEventListener("resize", updateEdges);
		updateEdges();
	}
	} // end initHomepageAnimations

	// Schedule init after `load` + an idle slot. Animations only matter
	// when the user starts scrolling — the eager-init cost was poisoning
	// TBT.
	const ricHome =
		(window as unknown as { requestIdleCallback?: (cb: () => void) => number })
			.requestIdleCallback ||
		((cb: () => void) => window.setTimeout(cb, 1));

	if (document.readyState === "complete") {
		ricHome(() => void initHomepageAnimations());
	} else {
		window.addEventListener(
			"load",
			() => ricHome(() => void initHomepageAnimations()),
			{ once: true },
		);
	}
</script>
