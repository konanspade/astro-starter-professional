	{/* ============================================================ */}
	{/* TALK TO EXPERTS — boxed card with rounded corners (not       */}
	{/* full-bleed). Aerial bg + green-tinted dark overlay, centred  */}
	{/* copy, single green pill CTA.                                 */}
	{/* ============================================================ */}
	<section class="px-5 pb-12 sm:px-10 sm:pb-16 lg:px-12 lg:pb-24">
		<div class="mx-auto max-w-[var(--container-site)]">
			<div class="relative overflow-hidden rounded-image">
				<img
					src="/images/forest-aerial-1600.webp"
					alt=""
					aria-hidden="true"
					class="absolute inset-0 h-full w-full object-cover"
					loading="lazy"
				/>
				{/* Two-layer overlay — deep dark wash for legibility plus a */}
				{/* faint accent-green tint to push the colour cast toward   */}
				{/* the brand without losing contrast.                       */}
				<div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>
				<div
					class="absolute inset-0 bg-brand-accent/[0.08] mix-blend-overlay"
					aria-hidden="true"
				></div>

				<div class="relative px-5 py-14 text-center sm:px-10 sm:py-20 lg:py-28">
					<div class="mx-auto max-w-3xl">
						<h2
							class="font-display text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-[1.15] tracking-tight text-white"
						>
							Join the mission for{" "}
							<span class="text-brand-accent">stronger, more sustainable</span>{" "}
							ground engineering.
						</h2>
						<p class="mt-5 font-sans text-base leading-relaxed text-white/80 sm:text-lg">
							Let's work together to engineer durable foundations, optimise
							materials, and deliver measurable impact on every project.
						</p>
						<PillLink href="/contact/" size="lg" shadow class="mt-8">
