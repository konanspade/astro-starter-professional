					</SectionHeader>

					<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
						{caseStudies.slice(0, 2).map((cs, idx) => (
							<CaseStudyCard
								caseStudy={cs}
								stats={getCaseStudyStats(cs)}
								pillVariant={idx % 2 === 0 ? "dark" : "accent"}
							/>
