			</div>

			{/* Marquee — full-bleed, fades softly at both edges so cards
			    don't pop in/out abruptly. The rail itself contains the
			    same TESTIMONIALS array twice for a seamless loop. */}
			<div
				class="testimonials-marquee relative mt-14 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]"
			>
				<ul class="testimonial-rail flex w-max gap-6">
					{
						(() => {
							// Prefer live ACF testimonials; fall back to the in-file
							// constants if the REST call hasn't populated them.
							const source = testimonials.length > 0 ? testimonials : TESTIMONIALS;
							// Duplicated for the seamless marquee loop.
							return [...source, ...source].map((t, i) => (
								<li
									aria-hidden={i >= source.length ? "true" : undefined}
									class="flex w-[320px] shrink-0 flex-col rounded-card bg-paper p-6 shadow-[0_18px_40px_-15px_rgba(0,0,0,0.45)]"
								>
								<div class="flex items-center gap-3">
									<span class="flex h-10 w-10 items-center justify-center rounded-pill bg-brand-accent-soft font-display text-sm font-bold text-ink">
										{t.name
											.split(" ")
											.map((n) => n[0])
											.join("")}
									</span>
									<div>
										<p class="font-display text-sm font-semibold text-ink">
											{t.name}
										</p>
										<p class="font-sans text-[11px] text-ink-mute">{t.role}</p>
									</div>
								</div>
								<p class="mt-4 font-sans text-sm leading-relaxed text-ink-soft">
									&ldquo;{t.body}&rdquo;
								</p>
							</li>
							));
						})()
					}
				</ul>
			</div>
		</div>
	</section>

	{/* ============================================================ */}
	{/* CASE STUDIES — 2-up split-card grid pulled from WP posts in   */}
	{/* the `case-studies` category. Each card is its own internal    */}
	{/* 2-col split: left = title + stats + CTA; right = image.       */}
	{/* ============================================================ */}
	{
		caseStudies.length > 0 && (
			<section class="bg-paper-cool px-5 py-16 sm:px-10 sm:py-20 lg:px-12 lg:py-28">
				<div class="mx-auto max-w-[var(--container-site)]">
					<SectionHeader eyebrow="Case studies" class="mb-10 sm:mb-12">
						<h2
							slot="heading"
							class="mt-5 font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold leading-[1.1] tracking-tight text-ink"
						>
							Sustainability delivered.{" "}
							<span class="text-ink-mute">Impactful case studies</span>{" "}
							from our clients.
