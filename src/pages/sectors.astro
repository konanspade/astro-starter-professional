---
/**
 * /sectors/ — placeholder archive listing for the suitable_sectors CPT.
 * See our-products.astro for rationale; replaced by the new design.
 */
import MainLayout from "../layouts/MainLayout.astro";

interface SectorNode {
	id: string;
	title: string;
	uri: string;
	excerpt?: string | null;
	featuredImage?: { node?: { mediaItemUrl: string; altText: string } | null } | null;
}

const apiUrl = import.meta.env.WORDPRESS_API_URL;
let sectors: SectorNode[] = [];
try {
	const response = await fetch(apiUrl, {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({
			query: `query AllSectors {
				sectors(first: 100) {
					nodes {
						id
						title
						uri
						excerpt
						featuredImage { node { mediaItemUrl altText } }
					}
				}
			}`,
		}),
	});
	const json = await response.json();
	sectors = json?.data?.sectors?.nodes ?? [];
} catch (err) {
	console.error("sectors: fetch failed", err);
}
---

<MainLayout title="Sectors" description="Industries and sectors served by Ocean Geosynthetics.">
	<section class="mx-auto max-w-6xl px-4 py-12">
		<header class="mb-8">
			<h1 class="text-3xl font-semibold">Sectors</h1>
			<p class="mt-2 text-[var(--color-text-muted)]">
				{sectors.length} sector{sectors.length === 1 ? "" : "s"}.
			</p>
		</header>

		{sectors.length === 0 ? (
			<p>No sectors to show.</p>
		) : (
			<ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{sectors.map((s) => (
					<li class="rounded border border-gray-200 p-4 transition hover:shadow">
						<a href={s.uri} class="block">
							{s.featuredImage?.node?.mediaItemUrl && (
								<img
									src={s.featuredImage.node.mediaItemUrl}
									alt={s.featuredImage.node.altText || s.title}
									class="mb-3 aspect-video w-full rounded object-cover"
									loading="lazy"
								/>
							)}
							<h2 class="text-lg font-medium" set:html={s.title} />
							{s.excerpt && (
								<div class="mt-2 text-sm text-[var(--color-text-muted)]" set:html={s.excerpt} />
							)}
						</a>
					</li>
				))}
			</ul>
		)}
	</section>
</MainLayout>
