---
/**
 * /news-updates/ — placeholder archive listing.
 *
 * On the existing site this is WP page id 13 (slug "news-updates")
 * rendered by Bricks as an archive of the "Insights" / "Case Studies"
 * category posts. WPGraphQL returns it with a null URI (Bricks marks
 * it as an archive shell), so it doesn't come through getAllUris.
 * Recreated here as a static Astro page until the new design lands.
 */
import MainLayout from "../layouts/MainLayout.astro";

interface PostNode {
	id: string;
	title: string;
	uri: string;
	date: string;
	excerpt?: string | null;
	featuredImage?: { node?: { mediaItemUrl: string; altText: string } | null } | null;
	categories?: { nodes?: { name: string; uri: string }[] } | null;
}

const apiUrl = import.meta.env.WORDPRESS_API_URL;
let posts: PostNode[] = [];
try {
	const response = await fetch(apiUrl, {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({
			query: `query NewsUpdatesPosts {
				posts(first: 50) {
					nodes {
						id
						title
						uri
						date
						excerpt
						featuredImage { node { mediaItemUrl altText } }
						categories { nodes { name uri } }
					}
				}
			}`,
		}),
	});
	const json = await response.json();
	posts = json?.data?.posts?.nodes ?? [];
} catch (err) {
	console.error("news-updates: fetch failed", err);
}
---

<MainLayout title="News & Updates" description="Latest articles and case studies from Ocean Geosynthetics.">
	<section class="mx-auto max-w-5xl px-4 py-12">
		<header class="mb-8">
			<h1 class="text-3xl font-semibold">News &amp; Updates</h1>
			<p class="mt-2 text-[var(--color-text-muted)]">
				{posts.length} post{posts.length === 1 ? "" : "s"} (most recent first).
			</p>
		</header>

		{posts.length === 0 ? (
			<p>No posts to show.</p>
		) : (
			<ul class="space-y-6">
				{posts.map((p) => (
					<li class="rounded border border-gray-200 p-4 transition hover:shadow">
						<a href={p.uri} class="flex flex-col gap-3 sm:flex-row">
							{p.featuredImage?.node?.mediaItemUrl && (
								<img
									src={p.featuredImage.node.mediaItemUrl}
									alt={p.featuredImage.node.altText || p.title}
									class="h-32 w-full shrink-0 rounded object-cover sm:w-48"
									loading="lazy"
								/>
							)}
							<div class="flex-1">
								<h2 class="text-lg font-medium" set:html={p.title} />
								<p class="mt-1 text-xs text-[var(--color-text-muted)]">
									{new Date(p.date).toLocaleDateString()}
									{p.categories?.nodes?.length
										? " · " + p.categories.nodes.map((c) => c.name).join(", ")
										: ""}
								</p>
								{p.excerpt && (
									<div class="mt-2 text-sm text-[var(--color-text-muted)]" set:html={p.excerpt} />
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		)}
	</section>
</MainLayout>
