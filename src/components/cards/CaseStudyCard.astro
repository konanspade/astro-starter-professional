---
/**
 * CaseStudyCard — split card for case study tiles. Left column: title +
 * stat dl + CTA pill. Right column: featured image.
 *
 * `pillVariant` toggles between dark and accent so a row of cards can
 * alternate (matches the homepage layout). `stats` is an array of
 * { value, label } pairs (typically 2 rows).
 */
import ArrowIcon from "../ui/ArrowIcon.astro";

interface Props {
	caseStudy: {
		title: string;
		uri: string;
		featuredImage?: { node?: { mediaItemUrl: string; altText: string } | null } | null;
	};
	stats?: { value: string; label: string }[];
	pillVariant?: "dark" | "accent";
	class?: string;
}

const {
	caseStudy,
	stats = [],
	pillVariant = "accent",
	class: className = "",
} = Astro.props;

const img = caseStudy.featuredImage?.node;
const titlePlain = caseStudy.title.replace(/<[^>]+>/g, "");
---

<article
	class:list={[
		"group rounded-card bg-paper p-5 shadow-sm transition-shadow duration-300 hover:shadow-xl sm:p-6",
		className,
	]}
>
	<div class="grid grid-cols-1 gap-5 sm:grid-cols-[5fr_6fr] sm:gap-6">
		<div class="flex flex-col">
			<h3
				class="font-display text-lg font-semibold leading-snug text-ink sm:text-xl"
				set:html={caseStudy.title}
			/>
			{stats.length > 0 && (
				<dl class="mt-5 divide-y divide-dashed divide-ink/15 border-y border-dashed border-ink/15">
					{stats.map((s) => (
						<div class="flex items-baseline gap-3 py-3">
							<dt class="font-display text-lg font-semibold text-ink sm:text-xl">
								{s.value}
							</dt>
							<dd class="font-sans text-[13px] leading-snug text-ink-mute">
								{s.label}
							</dd>
						</div>
					))}
				</dl>
			)}
			<a
				href={caseStudy.uri}
				aria-label={`Read case study: ${titlePlain}`}
				class:list={[
					"mt-auto inline-flex w-fit items-center gap-1.5 rounded-pill px-5 py-2.5 font-sans text-[13px] font-semibold transition-colors",
					pillVariant === "dark"
						? "bg-ink text-white hover:bg-ink-soft"
						: "bg-brand-accent text-ink hover:bg-brand-accent-hover",
					stats.length === 0 && "mt-6",
				]}
			>
				View case
				<ArrowIcon size="xs" />
			</a>
		</div>
		<a
			href={caseStudy.uri}
			tabindex="-1"
			class="relative aspect-[5/4] overflow-hidden rounded-image bg-paper-cool"
		>
			{img?.mediaItemUrl ? (
				<img
					src={img.mediaItemUrl}
					alt={img.altText || caseStudy.title}
					class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
					loading="lazy"
				/>
			) : (
				<div class="flex h-full w-full items-center justify-center text-ink-mute/40">
					<svg
						class="h-12 w-12"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						aria-hidden="true"
					>
						<rect x="3" y="3" width="18" height="18" rx="2"></rect>
						<path d="M3 16l5-5 4 4 3-3 6 6"></path>
						<circle cx="9" cy="9" r="1.5"></circle>
					</svg>
				</div>
			)}
		</a>
	</div>
</article>
