---
/**
 * Site footer — Mivora-style: full-bleed image background with two rounded
 * white cards on top (left = brand/newsletter, right = nav columns), plus
 * a bottom strip with copyright + agency credit. All copy and contact
 * details are pulled from oceangeosynthetics.com (live site is the source
 * of truth — keep these in sync).
 */

const PAGES = [
	{ label: "Products", href: "/our-products/" },
	{ label: "Sectors", href: "/sectors/" },
	{ label: "Solutions", href: "/solutions/" },
	{ label: "About Us", href: "/about-us/" },
	{ label: "Case Studies", href: "/case-studies/" },
	{ label: "Insights", href: "/news-updates/" },
	{ label: "Contact", href: "/contact/" },
	{ label: "Privacy Policy", href: "/terms-policies/" },
];

const SOCIAL = [
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/company/ocean-non-wovens-pvt-ltd/",
		path: "M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.22.79 24 1.77 24h20.46C23.21 24 24 23.22 24 22.27V1.72C24 .77 23.21 0 22.23 0z",
	},
	{
		label: "Instagram",
		href: "https://www.instagram.com/oceanglobalog",
		path: "M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.86 5.86 0 0 0-2.13 1.38A5.86 5.86 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.73 1.46 1.38 2.13.67.65 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.73 2.13-1.38.65-.67 1.07-1.34 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.86 5.86 0 0 0-1.38-2.13A5.86 5.86 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z",
	},
	{
		label: "YouTube",
		href: "https://www.youtube.com/channel/UCe0Aw7paUQqwZPS4L7G7UCA",
		path: "M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.6 12 3.6 12 3.6s-7.6 0-9.4.5A3 3 0 0 0 .5 6.2C0 8 0 12 0 12s0 4 .5 5.8a3 3 0 0 0 2.1 2.1C4.4 20.4 12 20.4 12 20.4s7.6 0 9.4-.5a3 3 0 0 0 2.1-2.1c.5-1.8.5-5.8.5-5.8s0-4-.5-5.8zM9.6 15.6V8.4l6.4 3.6-6.4 3.6z",
	},
	{
		label: "Twitter",
		href: "https://twitter.com/oceanglobalog",
		path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z",
	},
	{
		label: "Facebook",
		href: "https://www.facebook.com/OceanglobalOG/",
		path: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z",
	},
];

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-brand-blue-ink" role="contentinfo">
	<div class="relative">
		{/* Background image + dark overlay */}
		<img
			src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=2400&q=80"
			alt=""
			class="absolute inset-0 h-full w-full object-cover"
			loading="lazy"
			aria-hidden="true"
		/>
		<div
			class="absolute inset-0 bg-brand-blue-ink/75"
			aria-hidden="true"
		>
		</div>

		<div
			class="relative mx-auto max-w-[var(--container-site)] px-4 py-16 sm:py-20 lg:px-6 lg:py-24"
		>
			{/* === Two-card grid === */}
			<div class="grid grid-cols-1 gap-4 lg:grid-cols-12 lg:gap-5">
				{/* LEFT CARD — logo top, tagline+form vertically centered,
				    copyright pinned to bottom. */}
				<div
					class="flex min-h-[420px] flex-col rounded-card bg-white p-8 lg:col-span-5 lg:min-h-0 lg:p-10"
				>
					<a href="/" class="flex items-center gap-2" rel="home">
						<img
							src="/ocean-logo.svg"
							alt="Ocean Global"
							class="h-9 w-9"
							width="36"
							height="36"
						/>
						<span
							class="font-display text-base font-extrabold uppercase tracking-[0.04em] text-ink sm:text-lg"
						>
							Ocean Global<sup
								class="ml-0.5 text-[10px] font-semibold text-ink/60">™</sup
							>
						</span>
					</a>

					<div class="flex flex-1 items-center py-10">
						<div>
							<p
								class="max-w-md font-display text-2xl font-semibold leading-tight tracking-tight text-ink sm:text-[28px]"
							>
								We believe real change starts
								<span class="text-brand-accent">
									deep within the ground itself.
								</span>
							</p>
							<p class="mt-4 font-sans text-sm text-ink-mute">
								Join the engineering community.
							</p>

							<form
								action="/contact/"
								method="get"
								class="mt-6 flex flex-col gap-2 sm:flex-row"
							>
								<input
									type="email"
									name="email"
									required
									placeholder="Type your email"
									class="flex-1 rounded-full border border-ink/10 bg-white px-5 py-3 font-sans text-sm text-ink placeholder-ink-mute outline-none transition focus:border-brand-blue"
								/>
								<button
									type="submit"
									class="shrink-0 rounded-full bg-brand-accent px-6 py-3 font-sans text-sm font-semibold text-ink transition hover:bg-brand-accent-hover"
								>
									Subscribe
								</button>
							</form>
						</div>
					</div>

					<p class="font-sans text-xs text-ink-mute">
						&copy; {currentYear} Ocean Non Wovens Pvt. Ltd. All rights reserved.
					</p>
				</div>

				{/* RIGHT CARD — 2x2 grid with dashed dividers between cells.
				    Top row: Links | Address — Bottom row: Contact | Social */}
				<div
					class="rounded-card bg-white p-8 lg:col-span-7 lg:p-10"
				>
					<div class="grid grid-cols-1 sm:grid-cols-2">
						{/* TOP-LEFT — Links (split into two sub-columns when many items) */}
						<div class="pb-10 sm:border-r sm:border-dashed sm:border-ink/15 sm:pb-10 sm:pr-8 lg:pr-12">
							<h3 class="font-display text-2xl font-semibold text-ink">Links</h3>
							<ul class="mt-5 grid grid-cols-2 gap-x-6 gap-y-3 font-sans text-[15px]">
								{
									PAGES.map((item) => (
										<li>
											<a
												href={item.href}
												class="text-ink-soft transition hover:text-ink"
											>
												{item.label}
											</a>
										</li>
									))
								}
							</ul>
						</div>

						{/* TOP-RIGHT — Address */}
						<div class="border-t border-dashed border-ink/15 pt-10 pb-10 sm:border-t-0 sm:pt-0 sm:pl-8 lg:pl-12">
							<h3 class="font-display text-2xl font-semibold text-ink">Address</h3>
							<address class="mt-5 space-y-3 font-sans text-[15px] not-italic text-ink-soft">
								<p>
									<span class="block font-medium text-ink">
										Ocean Non Wovens Pvt. Ltd.
									</span>
									Mianwali Nagar,<br />New Delhi 110087, India
								</p>
							</address>
						</div>

						{/* BOTTOM-LEFT — Contact */}
						<div class="border-t border-dashed border-ink/15 pt-10 sm:border-r sm:border-dashed sm:border-ink/15 sm:pr-8 lg:pr-12">
							<h3 class="font-display text-2xl font-semibold text-ink">Contact</h3>
							<ul class="mt-5 space-y-3 font-sans text-[15px]">
								<li>
									<a
										href="mailto:sales@oceangeosynthetics.com"
										class="text-ink-soft transition hover:text-ink"
									>
										sales@oceangeosynthetics.com
									</a>
								</li>
								<li>
									<a
										href="tel:+918447226007"
										class="text-ink-soft transition hover:text-ink"
									>
										+91 8447 226 007
									</a>
								</li>
								<li>
									<a
										href="tel:+911145120291"
										class="text-ink-soft transition hover:text-ink"
									>
										+91 11 4512 0291
									</a>
								</li>
							</ul>
						</div>

						{/* BOTTOM-RIGHT — Social */}
						<div class="border-t border-dashed border-ink/15 pt-10 sm:pl-8 lg:pl-12">
							<h3 class="font-display text-2xl font-semibold text-ink">
								Social media
							</h3>
							<ul class="mt-5 flex flex-wrap gap-2">
								{
									SOCIAL.map((s) => (
										<li>
											<a
												href={s.href}
												target="_blank"
												rel="noopener noreferrer"
												aria-label={s.label}
												class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-paper-cool text-ink transition hover:bg-brand-accent"
											>
												<svg
													class="h-4 w-4"
													viewBox="0 0 24 24"
													fill="currentColor"
													aria-hidden="true"
												>
													<path d={s.path} />
												</svg>
											</a>
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</div>
			</div>

			{/* === Bottom strip === */}
			{/* Bottom strip removed — copyright now lives at the bottom of
			    the left card. */}
		</div>
	</div>
</footer>
